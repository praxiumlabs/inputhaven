{
  "name": "@inputhaven/react",
  "version": "1.0.0",
  "description": "Official InputHaven React Components - Drop-in form components",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.tsx --format cjs,esm --dts --clean --external react --external react-dom",
    "dev": "tsup src/index.tsx --format cjs,esm --dts --watch --external react --external react-dom",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "inputhaven",
    "react",
    "forms",
    "components",
    "ufp",
    "universal-form-protocol"
  ],
  "author": "InputHaven",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/inputhaven/react"
  },
  "homepage": "https://inputhaven.com",
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
