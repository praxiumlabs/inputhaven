{
  "name": "inputhaven-cli",
  "version": "1.0.0",
  "description": "InputHaven CLI - Create and manage forms from the command line",
  "main": "./dist/index.js",
  "bin": {
    "inputhaven": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs --clean",
    "dev": "tsup src/index.ts --format cjs --watch",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "inputhaven",
    "cli",
    "forms",
    "ufp"
  ],
  "author": "InputHaven",
  "license": "MIT",
  "dependencies": {
    "@inputhaven/sdk": "^1.0.0",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0",
    "inquirer": "^9.0.0",
    "conf": "^12.0.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.0",
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
