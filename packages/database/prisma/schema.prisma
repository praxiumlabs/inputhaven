// Prisma Schema for InputHaven v2
// Universal Form Protocol (UFP) - The Standard for AI-Era Data Collection

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== AUTH & USERS ====================

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  emailVerified       DateTime?
  passwordHash        String?
  name                String
  avatar              String?
  
  // OAuth
  googleId            String?   @unique
  githubId            String?   @unique
  
  // Plan & Billing
  plan                Plan      @default(FREE)
  planExpiresAt       DateTime?
  stripeCustomerId    String?   @unique
  stripeSubscriptionId String?
  
  // Usage tracking
  submissionsThisMonth Int      @default(0)
  submissionsTotal    Int       @default(0)
  storageUsedBytes    BigInt    @default(0)
  
  // Security
  twoFactorEnabled    Boolean   @default(false)
  twoFactorSecret     String?
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?
  lastLoginIp         String?
  passwordChangedAt   DateTime?
  
  // Status
  isActive            Boolean   @default(true)
  isAdmin             Boolean   @default(false)
  
  // Timestamps
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  // Relations
  workspaces          WorkspaceMember[]
  ownedWorkspaces     Workspace[]       @relation("WorkspaceOwner")
  sessions            Session[]
  apiKeys             ApiKey[]
  auditLogs           AuditLog[]
  notifications       Notification[]
  
  @@index([email])
  @@index([stripeCustomerId])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token        String   @unique
  expiresAt    DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  
  @@index([userId])
  @@index([token])
}

enum Plan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

// ==================== WORKSPACES (TEAMS) ====================

model Workspace {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  logo         String?
  
  // Owner
  ownerId      String
  owner        User     @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  
  // Settings
  customDomain String?
  
  // Timestamps
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  // Relations
  members      WorkspaceMember[]
  forms        Form[]
  integrations Integration[]
  apiKeys      ApiKey[]
  templates    Template[]
  
  @@index([ownerId])
  @@index([slug])
}

model WorkspaceMember {
  id           String   @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  role         WorkspaceRole @default(MEMBER)
  joinedAt     DateTime @default(now())
  
  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

// ==================== FORMS ====================

model Form {
  id              String   @id @default(cuid())
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  // Basic info
  name            String
  description     String?
  accessKey       String   @unique @default(cuid())
  
  // Schema (JSON Schema for validation)
  schema          Json     @default("{}")
  
  // Styling
  styling         Json     @default("{}")
  
  // Notifications
  emailTo         String[] @default([])
  webhookUrl      String?
  webhookSecret   String?
  
  // Redirect & Messages
  redirectUrl     String?
  successMessage  String   @default("Thank you for your submission!")
  
  // Security
  allowedDomains  String[] @default([])
  honeypotField   String   @default("_gotcha")
  requireAuth     Boolean  @default(false)
  
  // AI Features
  spamThreshold   Float    @default(0.7)
  autoTagEnabled  Boolean  @default(false)
  sentimentEnabled Boolean @default(false)
  
  // UFP Configuration
  ufpEnabled      Boolean  @default(true)
  ufpUri          String?  @unique  // ufp://inputhaven.com/f/{id}
  ufpSchema       Json?    // Full UFP schema
  semanticTypes   Json?    // Field to semantic type mapping
  
  // AI Configuration (Enhanced)
  aiEnabled           Boolean  @default(true)
  aiClassify          Boolean  @default(true)
  aiSentiment         Boolean  @default(true)
  aiSummarize         Boolean  @default(true)
  aiExtractEntities   Boolean  @default(true)
  aiAutoRespond       Boolean  @default(false)
  aiRoutingRules      Json     @default("[]")
  aiInstructions      Json?    // For AI agents
  
  // MCP Configuration
  mcpEnabled          Boolean  @default(true)
  mcpCapabilities     String[] @default(["submit", "query"])
  
  // Analytics
  submissionCount Int      @default(0)
  viewCount       Int      @default(0)
  conversionRate  Float    @default(0)
  
  // Status
  isActive        Boolean  @default(true)
  isArchived      Boolean  @default(false)
  lastSubmissionAt DateTime?
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  submissions     Submission[]
  webhookLogs     WebhookLog[]
  formViews       FormView[]
  autoResponders  AutoResponder[]
  templates       FormTemplate[]
  aiProcessors    AIProcessor[]
  publicListing   PublicForm?
  integrationLogs IntegrationLog[]
  
  @@index([workspaceId])
  @@index([accessKey])
  @@index([isActive])
  @@index([ufpUri])
}

model FormView {
  id        String   @id @default(cuid())
  formId    String
  form      Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  
  // Visitor info
  sessionId String
  ipAddress String?
  country   String?
  city      String?
  device    String?
  browser   String?
  referrer  String?
  
  // Funnel tracking
  startedAt DateTime @default(now())
  completedAt DateTime?
  droppedAt String?  // Field name where they dropped
  
  @@index([formId])
  @@index([sessionId])
  @@index([startedAt])
}

// ==================== SUBMISSIONS ====================

model Submission {
  id           String   @id @default(cuid())
  formId       String
  form         Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  
  // Submission data
  data         Json     // The actual form data
  metadata     Json     @default("{}")  // IP, user agent, etc.
  
  // AI Processing
  spamScore    Float?
  sentiment    String?  // positive, negative, neutral
  tags         String[] @default([])
  summary      String?  // AI-generated summary
  
  // Status
  isSpam       Boolean  @default(false)
  isRead       Boolean  @default(false)
  isStarred    Boolean  @default(false)
  isArchived   Boolean  @default(false)
  
  // Assignment
  assignedTo   String?
  status       SubmissionStatus @default(NEW)
  
  // Timestamps
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  // Relations
  files        FileUpload[]
  notes        SubmissionNote[]
  activities   SubmissionActivity[]
  
  @@index([formId])
  @@index([isSpam])
  @@index([isRead])
  @@index([status])
  @@index([createdAt])
}

enum SubmissionStatus {
  NEW
  IN_PROGRESS
  WAITING
  RESOLVED
  SPAM
}

model SubmissionNote {
  id           String   @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  userId       String
  content      String
  isInternal   Boolean  @default(true)
  createdAt    DateTime @default(now())
  
  @@index([submissionId])
}

model SubmissionActivity {
  id           String   @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  action       String   // status_changed, assigned, replied, etc.
  details      Json?
  userId       String?
  createdAt    DateTime @default(now())
  
  @@index([submissionId])
}

// ==================== FILES ====================

model FileUpload {
  id           String   @id @default(cuid())
  submissionId String?
  submission   Submission? @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  
  // File info
  originalName String
  storedName   String
  mimeType     String
  size         BigInt
  url          String
  
  // Security
  scanStatus   String   @default("pending") // pending, clean, infected
  scanResult   Json?
  
  // Timestamps
  createdAt    DateTime @default(now())
  expiresAt    DateTime?
  
  @@index([submissionId])
}

// ==================== WEBHOOKS & INTEGRATIONS ====================

model WebhookLog {
  id           String   @id @default(cuid())
  formId       String
  form         Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  
  url          String
  method       String   @default("POST")
  requestBody  Json?
  responseCode Int?
  responseBody String?
  duration     Int?     // ms
  success      Boolean  @default(false)
  error        String?
  attempts     Int      @default(1)
  
  createdAt    DateTime @default(now())
  
  @@index([formId])
  @@index([createdAt])
}

model Integration {
  id           String   @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  type         String   // slack, discord, notion, sheets, zapier, etc.
  name         String
  config       Json     // Encrypted config/credentials
  isActive     Boolean  @default(true)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  // Relations
  logs         IntegrationLog[]
  
  @@index([workspaceId])
  @@index([type])
}

model IntegrationLog {
  id            String      @id @default(cuid())
  integrationId String
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  
  formId        String
  form          Form        @relation(fields: [formId], references: [id], onDelete: Cascade)
  submissionId  String
  
  success       Boolean     @default(false)
  responseCode  Int?
  responseBody  String?     @db.Text
  error         String?
  duration      Int
  
  createdAt     DateTime    @default(now())
  
  @@index([integrationId])
  @@index([formId])
  @@index([createdAt])
}

model AutoResponder {
  id           String   @id @default(cuid())
  formId       String
  form         Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  
  name         String
  subject      String
  body         String   // Supports variables like {{name}}, {{email}}
  delay        Int      @default(0) // Minutes to wait before sending
  
  // Conditions
  conditions   Json?    // When to trigger
  isActive     Boolean  @default(true)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@index([formId])
}

// ==================== API KEYS ====================

model ApiKey {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId  String?
  workspace    Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  name         String
  keyHash      String   @unique // Hashed API key
  keyPreview   String   // First/last few chars for display
  
  // Permissions
  scopes       String[] @default(["read", "write"])
  
  // Usage
  lastUsedAt   DateTime?
  usageCount   BigInt   @default(0)
  
  // Limits
  rateLimit    Int      @default(1000) // Per hour
  expiresAt    DateTime?
  
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  
  // Relations
  mcpSessions  MCPSession[]
  
  @@index([userId])
  @@index([keyHash])
}

// ==================== RATE LIMITING ====================

model RateLimit {
  id           String   @id @default(cuid())
  key          String   @unique // ip:endpoint or user:endpoint
  count        Int      @default(0)
  windowStart  DateTime @default(now())
  expiresAt    DateTime
  
  @@index([key])
  @@index([expiresAt])
}

// ==================== AUDIT & NOTIFICATIONS ====================

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  action       String
  resource     String   // form, submission, user, etc.
  resourceId   String?
  details      Json?
  ipAddress    String?
  userAgent    String?
  
  createdAt    DateTime @default(now())
  
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model Notification {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type         String   // submission, team_invite, plan_limit, etc.
  title        String
  message      String
  link         String?
  isRead       Boolean  @default(false)
  
  createdAt    DateTime @default(now())
  
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

// ==================== EMAIL QUEUE ====================

model EmailQueue {
  id           String   @id @default(cuid())
  to           String
  subject      String
  body         String
  replyTo      String?
  
  status       String   @default("pending") // pending, sent, failed
  attempts     Int      @default(0)
  lastError    String?
  scheduledFor DateTime @default(now())
  sentAt       DateTime?
  
  createdAt    DateTime @default(now())
  
  @@index([status])
  @@index([scheduledFor])
}

// ==================== UNIVERSAL FORM PROTOCOL (UFP) ====================

model Template {
  id            String        @id @default(cuid())
  workspaceId   String
  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  // Identity
  name          String
  slug          String        // URL-friendly identifier
  description   String?
  type          TemplateType
  category      String?       // contact, support, lead-gen, feedback, etc.
  
  // UFP Schema
  ufpVersion    String        @default("1.0")
  schema        Json          // UFP Schema definition
  semantics     Json?         // Semantic type mappings
  variables     Json          @default("[]")
  
  // AI Configuration
  aiEnabled         Boolean   @default(true)
  aiInstructions    Json?     // Structured AI instructions
  aiModel           String?   
  aiTemperature     Float     @default(0.3)
  aiActions         Json      @default("[]")  // What AI should do
  
  // MCP Configuration
  mcpEnabled        Boolean   @default(true)
  mcpCapabilities   String[]  @default(["submit", "query"])
  
  // Content (for email/response templates)
  subject       String?
  body          String?
  bodyHtml      String?
  
  // Versioning
  version       Int           @default(1)
  isPublished   Boolean       @default(false)
  isSystem      Boolean       @default(false)  // Built-in templates
  isPublic      Boolean       @default(false)  // In public library
  
  // Stats
  usageCount    Int           @default(0)
  rating        Float?
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  // Relations
  versions      TemplateVersion[]
  forms         FormTemplate[]
  
  @@unique([workspaceId, slug])
  @@index([type])
  @@index([category])
  @@index([isPublic])
}

model TemplateVersion {
  id          String    @id @default(cuid())
  templateId  String
  template    Template  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  
  version     Int
  schema      Json
  changelog   String?
  createdBy   String?
  createdAt   DateTime  @default(now())
  
  @@unique([templateId, version])
  @@index([templateId])
}

model FormTemplate {
  id          String    @id @default(cuid())
  formId      String
  form        Form      @relation(fields: [formId], references: [id], onDelete: Cascade)
  templateId  String
  template    Template  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  
  purpose     String    // notification, auto_response, webhook, processor
  isActive    Boolean   @default(true)
  config      Json      @default("{}")
  
  createdAt   DateTime  @default(now())
  
  @@unique([formId, templateId, purpose])
  @@index([formId])
}

enum TemplateType {
  FORM_SCHEMA
  EMAIL_NOTIFICATION
  AUTO_RESPONSE
  WEBHOOK_PAYLOAD
  AI_PROCESSOR
  OUTPUT_TRANSFORM
  AGENT_INSTRUCTION
}

// AI Processing Pipeline
model AIProcessor {
  id            String   @id @default(cuid())
  formId        String
  form          Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  
  name          String
  description   String?
  order         Int      @default(0)  // Execution order
  
  // Trigger
  trigger       ProcessorTrigger  @default(ON_SUBMISSION)
  conditions    Json?     // When to run
  
  // AI Config
  provider      String    @default("anthropic")
  model         String    @default("claude-sonnet-4-20250514")
  systemPrompt  String    @db.Text
  userPrompt    String    @db.Text  // Template with {{variables}}
  temperature   Float     @default(0.3)
  maxTokens     Int       @default(1000)
  
  // Output
  outputType    ProcessorOutput
  outputSchema  Json?     // Expected output structure
  outputField   String?   // Where to store result
  
  // Post-processing
  actions       Json      @default("[]")
  
  isActive      Boolean   @default(true)
  
  // Stats
  executionCount  Int     @default(0)
  avgLatencyMs    Int?
  successRate     Float?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@index([formId])
}

enum ProcessorTrigger {
  ON_SUBMISSION
  ON_UPDATE
  ON_SCHEDULE
  ON_DEMAND
  ON_WEBHOOK
}

enum ProcessorOutput {
  CLASSIFICATION
  EXTRACTION
  SENTIMENT
  SUMMARY
  RESPONSE
  ROUTING
  SCORE
  TAGS
  CUSTOM
}

// MCP Sessions for AI Agents
model MCPSession {
  id            String    @id @default(cuid())
  
  // Identity
  agentId       String?   // AI agent identifier
  agentType     String?   // claude, gpt, custom
  sessionToken  String    @unique
  
  // Access
  apiKeyId      String?
  apiKey        ApiKey?   @relation(fields: [apiKeyId], references: [id])
  
  // Permissions
  allowedForms  String[]  @default([])  // Empty = all forms
  capabilities  String[]  @default(["submit", "query"])
  
  // Rate limiting
  requestCount  Int       @default(0)
  lastRequestAt DateTime?
  
  // Lifecycle
  expiresAt     DateTime
  isActive      Boolean   @default(true)
  
  createdAt     DateTime  @default(now())
  
  @@index([sessionToken])
  @@index([agentId])
}

// Semantic Type Registry
model SemanticType {
  id            String    @id @default(cuid())
  
  // Identity
  namespace     String    // person, organization, location, content, meta
  name          String    // full_name, email, address
  fullPath      String    @unique  // person.full_name
  
  // Definition
  description   String
  examples      String[]
  validation    Json?     // Validation rules
  formats       String[]  @default([])
  
  // AI Hints
  aiDescription String?
  aiExamples    String[]  @default([])
  
  // Standards mapping
  jsonSchemaType  String?   // string, number, boolean, etc.
  schemaOrgType   String?   // Schema.org mapping
  openApiFormat   String?   // OpenAPI format hint
  
  isSystem      Boolean   @default(true)
  
  createdAt     DateTime  @default(now())
  
  @@index([namespace])
}

// Public Form Directory (for discoverability)
model PublicForm {
  id            String    @id @default(cuid())
  formId        String    @unique
  form          Form      @relation(fields: [formId], references: [id], onDelete: Cascade)
  
  // Discoverability
  title         String
  description   String
  category      String
  tags          String[]
  
  // UFP URI
  ufpUri        String    @unique  // ufp://inputhaven.com/forms/{slug}
  
  // Verification
  isVerified    Boolean   @default(false)
  verifiedAt    DateTime?
  
  // Stats
  viewCount     Int       @default(0)
  submitCount   Int       @default(0)
  rating        Float?
  
  // SEO
  metaTitle     String?
  metaDescription String?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@index([category])
  @@index([tags])
}
