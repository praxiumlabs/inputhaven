{
  "name": "@inputhaven/sdk",
  "version": "1.0.0",
  "description": "Official InputHaven SDK for JavaScript/TypeScript - Universal Form Protocol",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/",
    "test": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "inputhaven",
    "forms",
    "ufp",
    "universal-form-protocol",
    "mcp",
    "ai",
    "form-backend",
    "form-api"
  ],
  "author": "InputHaven",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/inputhaven/sdk-js"
  },
  "homepage": "https://inputhaven.com",
  "dependencies": {
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "typescript": ">=4.7.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
